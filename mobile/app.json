{
  "expo": {
    "name": "Copilot Monitor",
    "slug": "copilot-monitor",
    "version": "0.1.1",
    "orientation": "default",
    "icon": "./assets/images/copilot-monitor-icon.png",
    "scheme": "copilot-monitor",
    "userInterfaceStyle": "dark",
    "ios": {
      "icon": "./assets/images/copilot-monitor-icon.png",
      "buildNumber": "1000",
      "supportsTablet": true,
      "bundleIdentifier": "com.nanoleft.copilotmonitor",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Copilot Monitor to scan a pairing code from VS Code.",
        "NSLocalNetworkUsageDescription": "Copilot Monitor connects securely to paired computers on your local network.",
        "NSMicrophoneUsageDescription": "Allow Copilot Monitor to record voice dictation for transcription on your paired computer.",
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "versionCode": 1000,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/copilot-monitor-icon.png",
        "monochromeImage": "./assets/images/copilot-monitor-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.nanoleft.copilotmonitor",
      "allowBackup": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/copilot-monitor-icon.png"
    },
    "plugins": [
      "./plugins/with-android-cleartext-traffic",
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Copilot Monitor to scan a pairing code from VS Code.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#111111",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0155609f-9678-47df-b2f1-c82fcb84b9fd"
      }
    },
    "owner": "nanoleft"
  }
}
