{
  "name": "githubcopilot-monitor",
  "publisher": "nanoleft",
  "displayName": "Copilot Monitor",
  "description": "Monitor and remotely control local GitHub Copilot Chat sessions from a responsive LAN dashboard.",
  "version": "1.1.8",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nanoleft-gh/copilot-monitor.git"
  },
  "bugs": {
    "url": "https://github.com/nanoleft-gh/copilot-monitor/issues"
  },
  "homepage": "https://github.com/nanoleft-gh/copilot-monitor#readme",
  "engines": {
    "vscode": "^1.128.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "copilot",
    "github-copilot",
    "chat",
    "ai",
    "monitor",
    "dashboard",
    "remote-control",
    "lan",
    "mobile",
    "mermaid",
    "agent",
    "productivity"
  ],
  "galleryBanner": {
    "color": "#000000",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "icon": "public/icon.png",
  "extensionDependencies": [
    "GitHub.copilot-chat"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "copilotMonitor",
          "title": "Copilot Monitor",
          "icon": "public/icon.svg"
        }
      ]
    },
    "views": {
      "copilotMonitor": [
        {
          "type": "webview",
          "id": "githubCopilotMonitor.mobile",
          "name": "Mobile"
        }
      ]
    },
    "commands": [
      {
        "command": "githubCopilotMonitor.start",
        "title": "Copilot Monitor: Start Dashboard"
      },
      {
        "command": "githubCopilotMonitor.stop",
        "title": "Copilot Monitor: Stop Dashboard"
      },
      {
        "command": "githubCopilotMonitor.open",
        "title": "Copilot Monitor: Open Dashboard"
      },
      {
        "command": "githubCopilotMonitor.copyUrl",
        "title": "Copilot Monitor: Copy Dashboard URL"
      }
    ],
    "configuration": {
      "title": "GitHub Copilot Monitor",
      "properties": {
        "githubCopilotMonitor.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Start the local dashboard bridge when this VS Code window starts."
        },
        "githubCopilotMonitor.port": {
          "type": "integer",
          "minimum": 1024,
          "maximum": 65535,
          "default": 43121,
          "scope": "machine",
          "description": "Stable LAN port shared by all open VS Code windows."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "npm run compile && node --test out/test/transcript.test.js out/test/modelCatalog.test.js out/test/modelConfigurationUpdate.test.js out/test/nativeChatInputState.test.js out/test/nativeInputStateSync.test.js out/test/hostIdentity.test.js out/test/lanAddress.test.js out/test/gatewayLease.test.js out/test/liveExportTracker.test.js out/test/sessionMatcher.test.js out/test/sessionStateCache.test.js out/test/toolDecision.test.js out/test/windowRegistry.test.js out/test/aggregateMonitor.test.js out/test/gateway.test.js out/test/monitorServer.test.js",
    "test:integration": "vscode-test",
    "package": "npm run compile && npx --yes @vscode/vsce package --no-dependencies",
    "publish:marketplace": "npm test && npx --yes @vscode/vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.128.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
